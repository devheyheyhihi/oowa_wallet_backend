# 백엔드 서버 포트
PORT=4000

# 프론트엔드에서 이 백엔드로 접근할 수 있도록 허용할 Origin 목록
# 로컬 개발에서는 현재 사용하는 프론트 포트들을 넣어두면 됩니다.
OOWA_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# 관리자 페이지(/admin) 로그인에 사용하는 단일 관리자 비밀번호
# 현재 구조에서는 관리자 아이디는 없고, 이 비밀번호 하나로 관리자 세션을 발급합니다.
OOWA_ADMIN_PASSWORD=change-me

# 서버에서 비밀번호 해시, 세션, 민감정보 암호화에 사용하는 앱 비밀값
# 운영에서는 반드시 길고 예측 불가능한 값으로 바꿔야 합니다.
OOWA_APP_SECRET=change-me

# 투자 기능에서 사용하는 투자 풀 지갑의 mnemonic
# private key 대신 mnemonic으로도 설정할 수 있습니다.
# 이 프로젝트는 mnemonic -> seed -> SHA256(seed) 방식으로 private key를 파생합니다.
# 절대 외부에 노출되면 안 됩니다.
OOWA_INVESTMENT_POOL_MNEMONIC=

# 투자 기능에서 "투자 시작" 시 사용자가 보내는 목적지 지갑의 private key
# mnemonic 대신 직접 private key를 넣고 싶을 때만 사용합니다.
# mnemonic과 private key를 둘 다 넣으면 private key가 우선합니다.
# 절대 외부에 노출되면 안 됩니다.
OOWA_INVESTMENT_POOL_PRIVATE_KEY=change-me

# 투자 풀 mnemonic/private key에서 파생되는 주소를 명시적으로 검증하고 싶을 때만 사용합니다.
# 비워두면 계산한 주소를 그대로 사용합니다.
OOWA_INVESTMENT_POOL_ADDRESS=
